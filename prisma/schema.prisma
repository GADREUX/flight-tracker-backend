// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  googleId     String   @unique
  email        String   @unique
  name         String?
  isPremium    Boolean  @default(false)
  premiumUntil DateTime?
  fcmToken     String?              // Firebase Cloud Messaging token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  watches      Watch[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Watches ──────────────────────────────────────────────────────────────────

model Watch {
  id                String      @id @default(cuid())
  userId            String
  origin            String      // IATA: "GRU"
  destination       String      // IATA: "LHR"
  departureDate     DateTime
  returnDate        DateTime?
  adults            Int         @default(1)
  cabinClass        CabinClass  @default(ECONOMY)
  thresholdPercent  Float       @default(10.0)
  alertOnRise       Boolean     @default(false)
  currency          String      @default("BRL")
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots         PriceSnapshot[]
  alerts            PriceAlert[]

  @@index([userId, isActive])
  @@index([departureDate])
}

enum CabinClass {
  ECONOMY
  BUSINESS
  FIRST
}

// ─── Price history ────────────────────────────────────────────────────────────

model PriceSnapshot {
  id          String   @id @default(cuid())
  watchId     String
  price       Float
  currency    String
  airline     String?
  source      String   @default("amadeus") // data source identifier
  checkedAt   DateTime @default(now())

  watch       Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([watchId, checkedAt])
}

// ─── Alerts fired ─────────────────────────────────────────────────────────────

model PriceAlert {
  id             String      @id @default(cuid())
  watchId        String
  oldPrice       Float
  newPrice       Float
  changePercent  Float
  direction      AlertDirection
  currency       String
  notified       Boolean     @default(false)
  notifiedAt     DateTime?
  createdAt      DateTime    @default(now())

  watch          Watch       @relation(fields: [watchId], references: [id], onDelete: Cascade)
}

enum AlertDirection {
  DROP
  RISE
}

// ─── Premium: route trend aggregates (populated nightly) ──────────────────────

model RouteTrend {
  id             String   @id @default(cuid())
  origin         String
  destination    String
  cabinClass     CabinClass
  month          Int      // 1-12
  year           Int
  avgPrice       Float
  minPrice       Float
  maxPrice       Float
  currency       String   @default("BRL")
  sampleCount    Int
  updatedAt      DateTime @updatedAt

  @@unique([origin, destination, cabinClass, month, year, currency])
  @@index([origin, destination])
}
